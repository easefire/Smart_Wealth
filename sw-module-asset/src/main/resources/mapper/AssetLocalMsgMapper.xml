<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.smartwealth.asset.mapper.AssetLocalMsgMapper">

    <!--
        【BUGFIX】之前 WHERE next_retry <= NOW() 配合 INSERT 时 next_retry=NULL，
                 会导致 NULL <= NOW() 评估为 NULL（=过滤掉），新消息永远扫不到。
                 加 IS NULL 兜底，确保首次插入的消息能立即被补偿任务捞起。
    -->
    <select id="selectPendingMsgs" resultType="com.smartwealth.asset.entity.AssetLocalMsg">
        SELECT * FROM t_asset_local_msg
        WHERE status = 0
          AND (next_retry IS NULL OR next_retry &lt;= NOW())
          AND (retry_count IS NULL OR retry_count &lt; 5)
        LIMIT 100
    </select>

    <!--
        【NEW for #13】只有 ConfirmCallback ack=true 才会调到这里，
                       依据业务级 msgId 精确更新，避免误改其它行。
    -->
    <update id="updateStatusSuccessByMsgId">
        UPDATE t_asset_local_msg
        SET status = 1
        WHERE msg_id = #{msgId}
          AND status = 0
    </update>
</mapper>